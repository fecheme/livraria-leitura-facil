@model LeituraFacil.Models.Carrinho
@{
    ViewData["Title"] = "Carrinho de Compras";
}

<div class="container py-5">
    <h2 class="fw-bold mb-4"><i class="bi bi-cart3 me-2 text-primary"></i>Carrinho de Compras</h2>

    @if (!Model.Itens.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-2 text-muted"></i>
            <h4 class="mt-3 text-muted">Seu carrinho está vazio</h4>
            <p class="text-muted">Adicione livros ao carrinho para continuar.</p>
            <a asp-controller="Produto" asp-action="Catalogo" class="btn btn-primary mt-2">
                <i class="bi bi-grid me-1"></i>Ver Catálogo
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Itens -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-0">
                        @foreach (var item in Model.Itens)
                        {
                            <div class="p-4 border-bottom d-flex gap-3 align-items-center">
                                <img src="@item.ImagemUrl" alt="@item.Titulo"
                                     style="width:60px;height:80px;object-fit:cover;border-radius:4px;"
                                     onerror="this.src='/images/livro-default.jpg'" />
                                <div class="flex-grow-1">
                                    <h6 class="fw-bold mb-1">@item.Titulo</h6>
                                    <small class="text-muted">@item.Autor</small>
                                    <div class="text-success fw-semibold">R$ @item.Preco.ToString("N2")</div>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <form asp-controller="Carrinho" asp-action="AlterarQuantidade" method="post"
                                          class="d-flex align-items-center gap-1">
                                        <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                        <input type="number" name="quantidade" value="@item.Quantidade"
                                               min="1" max="99" class="form-control text-center"
                                               style="width:70px;"
                                               onchange="this.form.submit()" />
                                    </form>
                                </div>
                                <div class="text-end" style="min-width:100px;">
                                    <div class="fw-bold text-success">R$ @item.Subtotal.ToString("N2")</div>
                                    <form asp-controller="Carrinho" asp-action="Remover" method="post" class="mt-1">
                                        <input type="hidden" name="produtoId" value="@item.ProdutoId" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i> Remover
                                        </button>
                                    </form>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center py-3">
                        <a asp-controller="Produto" asp-action="Catalogo" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-arrow-left me-1"></i>Continuar Comprando
                        </a>
                        <form asp-controller="Carrinho" asp-action="Limpar" method="post">
                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                    onclick="return confirm('Limpar todo o carrinho?')">
                                <i class="bi bi-trash me-1"></i>Limpar Carrinho
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Resumo -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-dark text-white py-3">
                        <h5 class="mb-0"><i class="bi bi-receipt me-2"></i>Resumo do Pedido</h5>
                    </div>
                    <div class="card-body">
                        @foreach (var item in Model.Itens)
                        {
                            <div class="d-flex justify-content-between mb-2 small">
                                <span class="text-muted text-truncate me-2" style="max-width:160px;">@item.Titulo (x@item.Quantidade)</span>
                                <span>R$ @item.Subtotal.ToString("N2")</span>
                            </div>
                        }
                        <hr />
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted">Total de itens:</span>
                            <span class="fw-semibold">@Model.TotalItens</span>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <span class="fw-bold fs-5">Total:</span>
                            <span class="fw-bold fs-4 text-success">R$ @Model.Total.ToString("N2")</span>
                        </div>
                        <button class="btn btn-success w-100 py-2" onclick="alert('Funcionalidade de pagamento não implementada nesta versão.')">
                            <i class="bi bi-credit-card me-2"></i>Finalizar Compra
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@model LeituraFacil.Models.Produto
@{
    ViewData["Title"] = "Editar Livro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark py-3">
                    <h4 class="mb-0"><i class="bi bi-pencil me-2"></i>Editar Livro</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Editar" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="DataCadastro" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="row g-3">
                            <div class="col-12">
                                <label asp-for="Titulo" class="form-label fw-semibold"></label>
                                <input asp-for="Titulo" class="form-control" />
                                <span asp-validation-for="Titulo" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Autor" class="form-label fw-semibold"></label>
                                <input asp-for="Autor" class="form-control" />
                                <span asp-validation-for="Autor" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Categoria" class="form-label fw-semibold"></label>
                                <select asp-for="Categoria" class="form-select">
                                    <option value="">Selecione...</option>
                                    <option>Fantasia</option>
                                    <option>Ficção Científica</option>
                                    <option>Clássico</option>
                                    <option>Literatura</option>
                                    <option>Não-Ficção</option>
                                    <option>Thriller</option>
                                    <option>Infantil</option>
                                    <option>Tecnologia</option>
                                    <option>Romance</option>
                                    <option>Biografia</option>
                                    <option>Outro</option>
                                </select>
                                <span asp-validation-for="Categoria" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Preco" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">R$</span>
                                    <input asp-for="Preco" class="form-control" />
                                </div>
                                <span asp-validation-for="Preco" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Editora" class="form-label fw-semibold"></label>
                                <input asp-for="Editora" class="form-control" />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Paginas" class="form-label fw-semibold"></label>
                                <input asp-for="Paginas" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ISBN" class="form-label fw-semibold"></label>
                                <input asp-for="ISBN" class="form-control" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold d-block">&nbsp;</label>
                                <div class="form-check form-switch mt-2">
                                    <input asp-for="Disponivel" class="form-check-input" role="switch" />
                                    <label asp-for="Disponivel" class="form-check-label">Disponível para venda</label>
                                </div>
                            </div>
                            <div class="col-12">
                                <label asp-for="ImagemUrl" class="form-label fw-semibold"></label>
                                <input asp-for="ImagemUrl" class="form-control" />
                            </div>
                            <div class="col-12">
                                <label asp-for="Descricao" class="form-label fw-semibold"></label>
                                <textarea asp-for="Descricao" class="form-control" rows="4"></textarea>
                                <span asp-validation-for="Descricao" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-warning px-4">
                                <i class="bi bi-check-lg me-1"></i>Salvar Alterações
                            </button>
                            <a asp-action="Gerenciar" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-1"></i>Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

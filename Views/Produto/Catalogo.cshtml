@model List<LeituraFacil.Models.Produto>
@{
    ViewData["Title"] = "Catálogo de Livros";
    var categorias = ViewBag.Categorias as List<string> ?? new List<string>();
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-grid me-2 text-primary"></i>Catálogo de Livros</h2>
        <span class="text-muted">@Model.Count livro(s) encontrado(s)</span>
    </div>

    <!-- Filtros -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body">
            <form asp-action="Catalogo" method="get" class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Buscar</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" name="busca" value="@ViewBag.Busca" class="form-control" placeholder="Título ou autor..." />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Categoria</label>
                    <select name="categoria" class="form-select">
                        <option value="">Todas as categorias</option>
                        @foreach (var cat in categorias)
                        {
                            <option value="@cat" selected="@(ViewBag.CategoriaAtual == cat)">@cat</option>
                        }
                    </select>
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary flex-fill">
                        <i class="bi bi-search me-1"></i>Filtrar
                    </button>
                    <a asp-action="Catalogo" class="btn btn-outline-secondary">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-search display-3 text-muted"></i>
            <h4 class="mt-3 text-muted">Nenhum livro encontrado</h4>
            <a asp-action="Catalogo" class="btn btn-primary mt-3">Ver todos os livros</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var produto in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 card-livro shadow-sm border-0">
                        <div class="card-img-container">
                            <img src="@produto.ImagemUrl" class="card-img-top" alt="@produto.Titulo"
                                 onerror="this.src='/images/livro-default.jpg'" />
                            <span class="badge bg-primary categoria-badge">@produto.Categoria</span>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold mb-1">@produto.Titulo</h6>
                            <p class="text-muted small mb-1">@produto.Autor</p>
                            <p class="text-muted small mb-auto">@produto.Editora</p>
                            <p class="fw-bold text-success fs-5 mt-2 mb-2">R$ @produto.Preco.ToString("N2")</p>
                            <a asp-controller="Produto" asp-action="Detalhes" asp-route-id="@produto.Id"
                               class="btn btn-primary btn-sm w-100">
                                <i class="bi bi-eye me-1"></i>Ver Detalhes
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@model List<LeituraFacil.Models.Produto>
@{
    ViewData["Title"] = "Gerenciar Produtos";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold mb-0"><i class="bi bi-gear me-2 text-secondary"></i>Gerenciar Produtos</h2>
        <a asp-action="Cadastrar" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i>Novo Livro
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-3 text-muted"></i>
                    <h5 class="mt-3 text-muted">Nenhum produto cadastrado ainda.</h5>
                    <a asp-action="Cadastrar" class="btn btn-success mt-2">Cadastrar primeiro livro</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-dark">
                            <tr>
                                <th>Capa</th>
                                <th>Título / Autor</th>
                                <th>Categoria</th>
                                <th>Preço</th>
                                <th>Status</th>
                                <th class="text-center">Ações</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model)
                            {
                                <tr>
                                    <td>
                                        <img src="@p.ImagemUrl" alt="@p.Titulo" style="height:60px;width:45px;object-fit:cover;border-radius:4px;"
                                             onerror="this.src='/images/livro-default.jpg'" />
                                    </td>
                                    <td>
                                        <div class="fw-semibold">@p.Titulo</div>
                                        <small class="text-muted">@p.Autor</small>
                                    </td>
                                    <td><span class="badge bg-primary">@p.Categoria</span></td>
                                    <td class="fw-bold text-success">R$ @p.Preco.ToString("N2")</td>
                                    <td>
                                        @if (p.Disponivel)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Disponível</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Indisponível</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Detalhes" asp-controller="Produto" asp-route-id="@p.Id"
                                               class="btn btn-sm btn-outline-primary" title="Ver">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Editar" asp-route-id="@p.Id"
                                               class="btn btn-sm btn-outline-warning" title="Editar">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Excluir" asp-route-id="@p.Id"
                                               class="btn btn-sm btn-outline-danger" title="Excluir">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@model LeituraFacil.Models.Produto
@{
    ViewData["Title"] = "Excluir Livro";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm border-danger">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0"><i class="bi bi-trash me-2"></i>Confirmar Exclusão</h4>
                </div>
                <div class="card-body p-4 text-center">
                    <img src="@Model.ImagemUrl" alt="@Model.Titulo"
                         style="height:150px; object-fit:contain;"
                         class="mb-3 rounded"
                         onerror="this.src='/images/livro-default.jpg'" />
                    <h5 class="fw-bold">@Model.Titulo</h5>
                    <p class="text-muted mb-1">@Model.Autor</p>
                    <p class="fw-bold text-success">R$ @Model.Preco.ToString("N2")</p>
                    <div class="alert alert-danger mt-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        Tem certeza que deseja excluir este livro? Esta ação não pode ser desfeita.
                    </div>
                    <div class="d-flex gap-2 justify-content-center mt-3">
                        <form asp-action="Excluir" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash me-1"></i>Sim, Excluir
                            </button>
                        </form>
                        <a asp-action="Gerenciar" class="btn btn-outline-secondary px-4">
                            <i class="bi bi-x-lg me-1"></i>Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

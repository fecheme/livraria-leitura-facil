@model LeituraFacil.Models.Produto
@{
    ViewData["Title"] = Model.Titulo;
}

<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Início</a></li>
            <li class="breadcrumb-item"><a asp-controller="Produto" asp-action="Catalogo">Catálogo</a></li>
            <li class="breadcrumb-item active">@Model.Titulo</li>
        </ol>
    </nav>

    <div class="row g-5">
        <!-- Imagem -->
        <div class="col-md-4 text-center">
            <div class="card border-0 shadow-sm p-3">
                <img src="@Model.ImagemUrl" alt="@Model.Titulo" class="img-fluid rounded"
                     style="max-height: 420px; object-fit: contain;"
                     onerror="this.src='/images/livro-default.jpg'" />
            </div>
            <span class="badge bg-primary fs-6 mt-3 px-3 py-2">@Model.Categoria</span>
        </div>

        <!-- Detalhes -->
        <div class="col-md-8">
            <h1 class="fw-bold mb-1">@Model.Titulo</h1>
            <p class="text-muted fs-5 mb-3">por <strong>@Model.Autor</strong></p>

            <div class="row g-2 mb-4">
                @if (!string.IsNullOrEmpty(Model.Editora))
                {
                    <div class="col-auto">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-building me-1"></i>@Model.Editora
                        </span>
                    </div>
                }
                @if (Model.Paginas > 0)
                {
                    <div class="col-auto">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-file-text me-1"></i>@Model.Paginas páginas
                        </span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.ISBN))
                {
                    <div class="col-auto">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-upc me-1"></i>ISBN: @Model.ISBN
                        </span>
                    </div>
                }
            </div>

            <div class="mb-4">
                <h5 class="fw-bold">Descrição</h5>
                <p class="text-muted lh-lg">@Model.Descricao</p>
            </div>

            <div class="card border-0 bg-light p-4 mb-4">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <span class="text-muted small">Preço</span>
                        <div class="display-6 fw-bold text-success">R$ @Model.Preco.ToString("N2")</div>
                    </div>
                    @if (Model.Disponivel)
                    {
                        <form asp-controller="Carrinho" asp-action="Adicionar" method="post" class="d-flex align-items-center gap-3">
                            <input type="hidden" name="produtoId" value="@Model.Id" />
                            <div class="d-flex align-items-center gap-2">
                                <label class="fw-semibold text-muted small">Qtd:</label>
                                <input type="number" name="quantidade" value="1" min="1" max="99"
                                       class="form-control text-center" style="width: 75px;" />
                            </div>
                            <button type="submit" class="btn btn-primary btn-lg px-4">
                                <i class="bi bi-cart-plus me-2"></i>Adicionar ao Carrinho
                            </button>
                        </form>
                    }
                    else
                    {
                        <span class="badge bg-secondary fs-6 px-3 py-2">Indisponível</span>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <a asp-controller="Produto" asp-action="Catalogo" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Voltar ao Catálogo
                </a>
                <a asp-controller="Carrinho" asp-action="Index" class="btn btn-outline-primary">
                    <i class="bi bi-cart3 me-1"></i>Ver Carrinho
                </a>
            </div>
        </div>
    </div>
</div>

@model List<LeituraFacil.Models.Produto>
@{
    ViewData["Title"] = "Início";
}

<!-- Hero -->
<section class="hero-section">
    <div class="container text-center">
        <i class="bi bi-book-half display-1 text-warning mb-3 d-block"></i>
        <h1 class="display-4 fw-bold text-white mb-3">Bem-vindo à Leitura Fácil</h1>
        <p class="lead text-light mb-4">Os melhores livros com os melhores preços. Encontre sua próxima leitura!</p>
        <a asp-controller="Produto" asp-action="Catalogo" class="btn btn-warning btn-lg px-5 fw-bold">
            <i class="bi bi-grid me-2"></i>Ver Catálogo Completo
        </a>
    </div>
</section>

<!-- Categorias -->
<section class="py-4 bg-light">
    <div class="container">
        <div class="d-flex gap-2 flex-wrap justify-content-center">
            @foreach (var cat in new[] { "Fantasia", "Clássico", "Ficção Científica", "Literatura", "Não-Ficção", "Thriller", "Infantil", "Tecnologia" })
            {
                <a asp-controller="Produto" asp-action="Catalogo" asp-route-categoria="@cat"
                   class="badge bg-primary text-decoration-none fs-6 px-3 py-2 rounded-pill">@cat</a>
            }
        </div>
    </div>
</section>

<!-- Destaques -->
<section class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0"><i class="bi bi-star-fill text-warning me-2"></i>Destaques</h2>
            <a asp-controller="Produto" asp-action="Catalogo" class="btn btn-outline-primary btn-sm">
                Ver todos <i class="bi bi-arrow-right"></i>
            </a>
        </div>
        <div class="row g-4">
            @foreach (var produto in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-2-4">
                    <div class="card h-100 card-livro shadow-sm border-0">
                        <div class="card-img-container">
                            <img src="@produto.ImagemUrl" class="card-img-top" alt="@produto.Titulo"
                                 onerror="this.src='/images/livro-default.jpg'" />
                            <span class="badge bg-primary categoria-badge">@produto.Categoria</span>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h6 class="card-title fw-bold mb-1 text-truncate">@produto.Titulo</h6>
                            <p class="text-muted small mb-2">@produto.Autor</p>
                            <p class="fw-bold text-success fs-5 mt-auto mb-2">R$ @produto.Preco.ToString("N2")</p>
                            <a asp-controller="Produto" asp-action="Detalhes" asp-route-id="@produto.Id"
                               class="btn btn-outline-primary btn-sm w-100">
                                <i class="bi bi-eye me-1"></i>Ver Detalhes
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Chamada para admin -->
<section class="py-5 bg-light">
    <div class="container text-center">
        <i class="bi bi-gear-fill display-5 text-secondary mb-3 d-block"></i>
        <h3 class="fw-bold">Área Administrativa</h3>
        <p class="text-muted">Gerencie o catálogo de livros: adicione, edite ou remova produtos.</p>
        <a asp-controller="Produto" asp-action="Gerenciar" class="btn btn-secondary px-4">
            <i class="bi bi-pencil-square me-2"></i>Ir para Gerenciamento
        </a>
    </div>
</section>
